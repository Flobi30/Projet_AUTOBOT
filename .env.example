# Configuration AUTOBOT V2
# Copiez ce fichier en .env et remplissez vos valeurs
# NE JAMAIS committer le fichier .env

# ─── OBLIGATOIRE — Clés API Kraken ────────────────────────────────────────────
KRAKEN_API_KEY=votre_clé_api_ici
KRAKEN_API_SECRET=votre_secret_api_ici

# ─── SÉCURITÉ Dashboard ───────────────────────────────────────────────────────
# Token Bearer obligatoire en production (APP_ENV != development)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_API_TOKEN=votre_token_secret_pour_dashboard

# Environnement d'exécution : production | staging | development
# En production et staging, DASHBOARD_API_TOKEN est OBLIGATOIRE
APP_ENV=production

# ─── CONFIGURATION OPTIONNELLE ────────────────────────────────────────────────
# URL API Kraken (override pour tests/sandbox)
# KRAKEN_API_URL=https://api.kraken.com

# Mode paper trading (aucun ordre réel passé)
# TEST_MODE=true

# ─── DASHBOARD ────────────────────────────────────────────────────────────────
# Hôte et port du serveur FastAPI dashboard
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8080

# ─── LOGGING ──────────────────────────────────────────────────────────────────
# Niveau de log : DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ─── MODULE ACTIVATION ───────────────────────────────────────────────────────
# Set to true/false to enable/disable individual modules.
# Safe modules (recommended ON):
# MODULE_DAILY_REPORTER=true
# MODULE_REBALANCE_MANAGER=true
# MODULE_AUTO_EVOLUTION=true
# MODULE_MARKET_ANALYZER=true
# MODULE_STRATEGY_ENSEMBLE=true
# MODULE_TRAILING_STOP_ATR=true
# MODULE_VOLATILITY_WEIGHTER=true
# MODULE_MOMENTUM_SCORING=true
# MODULE_MULTI_INDICATOR_VOTE=true
# MODULE_BLACK_SWAN=true

# Experimental modules (default OFF — enable with caution):
# MODULE_SHADOW_TRADING=false
# MODULE_PYRAMIDING_MANAGER=false
# MODULE_XGBOOST_PREDICTOR=false
# MODULE_PAIRS_TRADING=false
# MODULE_LIQUIDATION_HEATMAP=false
# MODULE_VWAP_TWAP=false
# MODULE_DCA_HYBRID=false
# MODULE_MICRO_GRID=false
# MODULE_SENTIMENT_NLP=false
# MODULE_HEURISTIC_PREDICTOR=false
# MODULE_ONCHAIN_DATA=false
# MODULE_MEAN_REVERSION=false        # PRODUCTION_READY=False
# MODULE_TRIANGULAR_ARBITRAGE=false   # PRODUCTION_READY=False

# ─── MODULE-SPECIFIC CONFIG ──────────────────────────────────────────────────
# AUTOEVOLUTION_DB=data/autoevolution.db
# PAIRS_TRADING_A=BTC/USD
# PAIRS_TRADING_B=ETH/USD
# ARBITRAGE_PAIRS=BTC/EUR,ETH/BTC,ETH/EUR
