# ===== Deployment / Promotion Gates (required) =====
APP_ENV=production
DEPLOYMENT_STAGE=paper
DASHBOARD_API_TOKEN=change_me
PAPER_TRADING=true
LIVE_TRADING_CONFIRMATION=false
PREFLIGHT_ONLY=false

# Dedicated API key per bot (required for live stages)
API_KEY_ASSIGNMENT_MODE=dedicated
ALLOW_SHARED_API_KEY=false
UNIQUE_BOT_ID=bot-01
API_KEY_ASSIGNED_BOT_ID=bot-01
MAX_LIVE_INSTANCES=1
SMALL_LIVE_APPROVED=false

# Secret compromise controls
LEAKED_SSH_KEY_ROTATED_ACK=false
SECRET_EXPOSURE_MARKER_PATH=data/compromised_secret.marker
KRAKEN_API_KEY_FINGERPRINT=

# ===== Risk Limits (required) =====
MAX_DRAWDOWN_PCT=10
RISK_PER_TRADE_PCT=1
MAX_POSITION_SIZE_PCT=20

# ===== Core =====
AUTOBOT_AUTONOMOUS=true
AUTOBOT_SAFE_MODE=true
AUTOBOT_FORCE_ENABLE_ALL=false
INITIAL_CAPITAL=1000.0

# ===== Runtime config (externalized) =====
HEALTH_SCORE_THRESHOLD=60
TRADE_ACTION_MIN_INTERVAL_S=1.5
MAX_REPEATED_AUTO_ACTIONS=3
MAX_BACKOFF_SECONDS=300
MAX_INSTANCES_PER_CYCLE=45
SPIN_OFF_THRESHOLD=1800
MIN_PF_FOR_SPINOFF=1.2
TARGET_VOLATILITY=0.02
WEBSOCKET_STREAMS=1
SAFETY_DSR_TIMEOUT_MS=50
SAFETY_DSR_CACHE_S=300
SAFETY_WF_LEARNING_DAYS=7
SAFETY_WF_MIN_TRADES_LEARNING=10
SAFETY_MAX_BLOCK_RATIO=0.8
SAFETY_EMERGENCY_CYCLE_MS=100
SAFETY_EMERGENCY_CONSECUTIVE=3

# ===== Decision priorities =====
DECISION_PRIORITY_RISK_BLOCK=100
DECISION_PRIORITY_EXIT=80
DECISION_PRIORITY_ENTRY=50
DECISION_PRIORITY_ADD=40

# ===== Feature toggles (ENABLE_*) =====
ENABLE_MEAN_REVERSION=true
ENABLE_SENTIMENT=true
ENABLE_ML=true
ENABLE_XGBOOST=true
ENABLE_ONCHAIN=true
ENABLE_TRADING_HEALTH_SCORE=true
ENABLE_SHADOW_PROMOTION=true
ENABLE_SHADOW_TRADING=true
ENABLE_REBALANCE=true
ENABLE_AUTO_EVOLUTION=true
ENABLE_VALIDATION_GUARD=true
ENABLE_CONFLICT_LOGGING=true
ENABLE_DECISION_JOURNAL=false

# ===== Dependency validation inputs =====
SENTIMENT_API_KEY=
ONCHAIN_API_KEY=
ONCHAIN_NODE_URL=https://api.blockchain.info
XGBOOST_MODEL_PATH=models/xgboost.pkl
HISTORICAL_DATA_PATH=data/historical
SHADOW_TRADING_DB_PATH=data/shadow_trading.db
WF_MIN_OOS_PF=1.05
WF_PURGE_BARS=2
WF_MIN_TRADES=40
VALIDATION_GUARD_INTERVAL_S=120
REGIME_HYSTERESIS_TICKS=3
CLUSTER_CAP_RATIO=0.35

# ===== Market selector =====
ALLOW_FOREX_SPINOFF=false

# ===== Optional integrations =====
AUTOEVOLUTION_DB=data/autoevolution.db
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ===== Decision Journal (Lot 1 analytics) =====
DECISION_JOURNAL_PATH=data/decision_journal.jsonl
DECISION_JOURNAL_FLUSH_EVERY=1
DECISION_JOURNAL_MAX_SYMBOLS=10
DECISION_JOURNAL_SESSION_ID=
