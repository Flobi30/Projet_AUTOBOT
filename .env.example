# ==============================
# Modes d'exécution (essentiel runtime)
# ==============================
APP_ENV=production                              # obligatoire: contexte applicatif (prod/dev)
DEPLOYMENT_STAGE=paper                          # obligatoire: gate de promotion (paper|micro_live|small_live)
PAPER_TRADING=true                              # obligatoire: true = simulation, false = ordres réels
PREFLIGHT_ONLY=true                             # obligatoire: true = checks only, aucun ordre exécuté
COMPOSE_BAKE=false                             # optionnel: evite l'avertissement buildx absent avec Docker Compose

# ==============================
# Sécurité / garde-fous live
# ==============================
LIVE_TRADING_CONFIRMATION=false                 # obligatoire: doit rester false en paper; true requis pour live
DASHBOARD_API_TOKEN=change_me                   # obligatoire: token auth API dashboard
API_KEY_ASSIGNMENT_MODE=dedicated               # obligatoire en live: clé dédiée par bot
ALLOW_SHARED_API_KEY=false                      # obligatoire: interdire partage de clé API
UNIQUE_BOT_ID=bot-paper-01                      # obligatoire: identifiant unique du bot
API_KEY_ASSIGNED_BOT_ID=bot-paper-01            # obligatoire: doit matcher UNIQUE_BOT_ID en live
MAX_LIVE_INSTANCES=1                            # obligatoire: limite de parallélisme live
SMALL_LIVE_APPROVED=false                       # optionnelle: gate explicite pour stage small_live

LEAKED_SSH_KEY_ROTATED_ACK=false                # obligatoire sécurité: passer à true uniquement APRÈS vérification opérationnelle de la rotation des secrets
SECRET_EXPOSURE_MARKER_PATH=data/compromised_secret.marker  # obligatoire sécurité: arrêt si marker présent
KRAKEN_API_KEY_FINGERPRINT=                     # optionnelle: empreinte de contrôle clé API

# ==============================
# Limites risque / capital (obligatoire)
# ==============================
INITIAL_CAPITAL=1000.0                          # obligatoire: capital de référence (paper par défaut)
PAPER_ALLOW_SYNTHETIC_PRICE_FALLBACK=false      # false: aucun prix paper invente; WebSocket ou prix signal obligatoire
MAX_DRAWDOWN_PCT=10                             # obligatoire: coupe-circuit drawdown global (%)
RISK_PER_TRADE_PCT=1                            # obligatoire: risque max par trade (%)
MAX_POSITION_SIZE_PCT=20                        # obligatoire: taille max d'une position (%)
RISK_MANAGER_GLOBAL_MIN_PF=1.2                  # disjoncteur PF global en live
RISK_MANAGER_PAPER_PF_STOP_ENABLED=false        # paper: PF bas loggue et continue par defaut
RISK_MANAGER_PAPER_MIN_CLOSED_TRADES_FOR_PF_STOP=30  # evidence minimale si hard-stop paper active
GRID_BLOCK_UNDERPERFORMING_HEALTH=true          # paper: stoppe les nouveaux BUY grid sur paires PF realise < 1
GRID_KELLY_ZERO_FALLBACK_MULT=0.25              # paper learning: taille canari si Kelly=0 et aucune preuve realisee

# ==============================
# Modèle cost/edge (audit trading)
# ==============================
COST_EDGE_PROFILE=balanced                      # conservative|balanced|exploratory_paper
EDGE_PERCENTILE_TARGET=0.75                     # percentile des coûts observés utilisé pour fee/slippage
EDGE_FALLBACK_FEE_BPS=40                        # cout fee fallback avant historique réel (bps)
EDGE_FALLBACK_SLIPPAGE_BPS=6                    # slippage fallback avant historique réel (bps)
EDGE_SLIPPAGE_SPREAD_FRACTION=0.35              # slippage fallback proportionnel au spread
EDGE_COST_BUFFER_MULT=1.0                       # balanced actuel: coût observé ajouté comme buffer
VOLATILITY_EDGE_WEIGHT=0.25                     # buffer volatilité: ATR% * 10000 * poids
COST_EDGE_AUDIT_HISTORY_SIZE=50                 # événements exposés dans /api/trading/debug

# Profils configurables. exploratory_paper est refusé automatiquement hors PAPER_TRADING=true.
COST_EDGE_CONSERVATIVE_RANGE_TP_RR=1.85
COST_EDGE_CONSERVATIVE_RANGE_MIN_EDGE_BPS=16
COST_EDGE_CONSERVATIVE_RANGE_COST_BUFFER_MULT=1.0
COST_EDGE_CONSERVATIVE_RANGE_VOLATILITY_EDGE_WEIGHT=0.35
COST_EDGE_CONSERVATIVE_TREND_TP_RR=2.10
COST_EDGE_CONSERVATIVE_TREND_MIN_EDGE_BPS=18
COST_EDGE_CONSERVATIVE_TREND_COST_BUFFER_MULT=1.0
COST_EDGE_CONSERVATIVE_TREND_VOLATILITY_EDGE_WEIGHT=0.35

COST_EDGE_BALANCED_RANGE_TP_RR=1.55
COST_EDGE_BALANCED_RANGE_MIN_EDGE_BPS=12
COST_EDGE_BALANCED_RANGE_COST_BUFFER_MULT=1.0
COST_EDGE_BALANCED_RANGE_VOLATILITY_EDGE_WEIGHT=0.25
COST_EDGE_BALANCED_TREND_TP_RR=1.75
COST_EDGE_BALANCED_TREND_MIN_EDGE_BPS=14
COST_EDGE_BALANCED_TREND_COST_BUFFER_MULT=1.0
COST_EDGE_BALANCED_TREND_VOLATILITY_EDGE_WEIGHT=0.25

COST_EDGE_EXPLORATORY_PAPER_RANGE_TP_RR=1.75
COST_EDGE_EXPLORATORY_PAPER_RANGE_MIN_EDGE_BPS=6
COST_EDGE_EXPLORATORY_PAPER_RANGE_COST_BUFFER_MULT=0.25
COST_EDGE_EXPLORATORY_PAPER_RANGE_VOLATILITY_EDGE_WEIGHT=0.10
COST_EDGE_EXPLORATORY_PAPER_TREND_TP_RR=1.95
COST_EDGE_EXPLORATORY_PAPER_TREND_MIN_EDGE_BPS=8
COST_EDGE_EXPLORATORY_PAPER_TREND_COST_BUFFER_MULT=0.25
COST_EDGE_EXPLORATORY_PAPER_TREND_VOLATILITY_EDGE_WEIGHT=0.10

# ==============================
# Scoring opportunites / selection autonome
# ==============================
OPPORTUNITY_SCORING_ENABLED=true                # calcule /api/opportunities depuis les traces runtime reelles
OPPORTUNITY_SELECTION_ENABLED=true              # applique la selection aux ordres en paper
OPPORTUNITY_SELECTION_LIVE_ENABLED=false        # live bloque par defaut; ne passer true qu'apres validation separee
OPPORTUNITY_MIN_SCORE=70                        # score minimum pour laisser passer une opportunite
OPPORTUNITY_MIN_GROSS_EDGE_BPS=35               # objectif: trade moins mais gross edge >= 35 bps
OPPORTUNITY_MIN_NET_EDGE_BPS=12                 # edge net minimum apres couts
OPPORTUNITY_MIN_ATR_BPS=18                      # evite les micro-mouvements trop calmes
OPPORTUNITY_ATR_MODE=strict                     # strict|adaptive|opportunistic; adaptive/opportunistic ne changent pas le live
OPPORTUNITY_HIGH_NET_EDGE_BPS=80                # paper adaptive: edge net eleve pouvant tolerer ATR plus bas
OPPORTUNITY_PAPER_RELAXED_MIN_ATR_BPS=5         # seuil ATR minimum absolu pour tolerance paper uniquement
OPPORTUNITY_MAX_ATR_BPS=220                     # evite les regimes trop violents
OPPORTUNITY_MAX_SPREAD_BPS=8                    # spread max pour opportunite tradable
OPPORTUNITY_MAX_COST_BPS=80                     # cout total max considere sain
OPPORTUNITY_MIN_STABILITY=0.45                  # stabilite minimale des signaux recents
OPPORTUNITY_MAX_ACTIVE_SYMBOLS=2                # priorise les meilleures paires seulement
OPPORTUNITY_MIN_ORDER_EUR=5                     # paper/live-compatible: ordre trop petit ignore
OPPORTUNITY_MAX_ORDER_EUR=25                    # cap prudent par ordre pendant validation
OPPORTUNITY_MAX_SYMBOL_EXPOSURE_PCT=20          # cap exposition par symbole
OPPORTUNITY_MAX_TOTAL_EXPOSURE_PCT=40           # cap exposition globale opportunites
OPPORTUNITY_PAPER_ALLOW_UPSIZE=true             # paper only: peut relever un signal trop petit vers l'allocation scoree
OPPORTUNITY_PAPER_ALLOW_MIN_ORDER_FLOOR=true     # paper only: peut monter au minimum executable si score/caps OK
OPPORTUNITY_PAPER_MIN_ORDER_EUR=10              # paper only: evite les micro-ordres peu mesurables
OPPORTUNITY_PAPER_MAX_ORDER_EUR=80              # paper only: cap par ordre pendant entrainement
OPPORTUNITY_PAPER_ORDER_CAPITAL_PCT=38          # paper only: plafond cible par ordre si score/edge excellents
OPPORTUNITY_PAPER_DYNAMIC_ALLOCATION_ENABLED=true # paper only: module l'ordre selon score + edge net
OPPORTUNITY_PAPER_MIN_ORDER_CAPITAL_PCT=12      # paper only: plancher de sizing quand opportunite valide
OPPORTUNITY_PAPER_EDGE_BOOST_BPS=140            # paper only: surplus d'edge net pour atteindre le plafond
OPPORTUNITY_PAPER_MAX_SYMBOL_EXPOSURE_PCT=25    # paper only: exposition max par paire
OPPORTUNITY_PAPER_MAX_TOTAL_EXPOSURE_PCT=80     # paper only: exposition globale max
OPPORTUNITY_PAIR_HEALTH_GUARD_ENABLED=true      # paper only: bloque les paires avec pertes realisees claires
OPPORTUNITY_PAIR_HEALTH_GUARD_MIN_CLOSED_TRADES=20 # evidence complete avant blocage weak
OPPORTUNITY_PAIR_HEALTH_GUARD_EARLY_MIN_CLOSED_TRADES=8 # evidence minimale pour blocage early_weak
OPPORTUNITY_PAIR_HEALTH_GUARD_SCORE_MAX=35      # score sante max pour blocage early_weak
OPPORTUNITY_PAIR_HEALTH_GUARD_PF_MAX=0.80       # PF max pour blocage early_weak
PAIR_HEALTH_SCORING_ENABLED=true                # paper/live-safe: ajuste score selon PnL realise trace_ledger
PAIR_HEALTH_LIVE_ENABLED=false                  # live inchangé par défaut; active seulement après validation
PAIR_HEALTH_MIN_CLOSED_TRADES=20                # evidence minimale avant bonus/penalite forte
PAIR_HEALTH_EARLY_WEAK_MIN_CLOSED_TRADES=8      # paper: detecte plus tot une paire en apprentissage deja perdante
PAIR_HEALTH_EARLY_WEAK_SCORE_MAX=35             # score sante max pour classer early_weak
PAIR_HEALTH_EARLY_WEAK_PF_MAX=0.80              # PF max pour classer early_weak
PAIR_HEALTH_EARLY_WEAK_PENALTY_MULTIPLIER=0.75  # penalite partielle avant evidence complete
PAIR_HEALTH_LOOKBACK_CLOSED_TRADES=80           # fenetre recente par paire/strategie
PAIR_HEALTH_MAX_BONUS=8                         # bonus max au score opportunite
PAIR_HEALTH_MAX_PENALTY=28                      # penalite max au score opportunite
PAIR_HEALTH_CACHE_SECONDS=30                    # evite de relire SQLite a chaque tick
PAIR_HEALTH_PF_FLOOR=0.75                       # PF faible penalise
PAIR_HEALTH_PF_TARGET=1.35                      # PF cible pour score sain
PAIR_HEALTH_ACTIVE_PF_FLOOR=1.0                 # PF minimum pour ne pas classer une paire sous-performante
PAIR_HEALTH_AVG_RETURN_TARGET_BPS=35            # retour moyen vise apres frais
SETUP_OPTIMIZER_ENABLED=true                    # paper only: compare plusieurs variantes par paire/regime
SETUP_OPTIMIZER_LIVE_ENABLED=false              # live inchangé; aucune promotion automatique
SETUP_OPTIMIZER_APPLY_TO_EXECUTION=true         # paper only: bloque les nouveaux BUY du setup officiel s'il sous-performe
SETUP_OPTIMIZER_EXECUTION_GATE_TTL_SECONDS=60   # cache du verdict optimizer pour ne pas relire la DB a chaque tick
SETUP_OPTIMIZER_MIN_CLOSED_TRADES=30            # preuves minimales avant candidat
SETUP_OPTIMIZER_CANDIDATE_PF=1.25               # PF minimum pour un setup candidat paper
SETUP_OPTIMIZER_STRONG_PF=1.60                  # PF fort pour bonus de selection
SETUP_OPTIMIZER_MIN_NET_PNL_EUR=0               # PnL minimum pour candidat paper
SETUP_OPTIMIZER_MAX_VARIANTS_PER_SYMBOL=5       # variantes comparees par paire surveillee
SETUP_OPTIMIZER_CANDIDATE_SCORE=70              # score minimum pour revue paper
SETUP_OPTIMIZER_WEAK_SCORE=45                   # score faible -> ajuster/observer
PAPER_EXECUTION_ROUTER_ENABLED=true             # paper only: applique une variante shadow grid candidate au ledger paper officiel
PAPER_EXECUTION_ROUTER_MIN_SCORE=70             # score minimum avant promotion paper officielle
PAPER_EXECUTION_ROUTER_BLOCK_PENDING=true       # bloque les nouveaux BUY de l'ancien setup tant que la paire n'est pas a plat
SETUP_SHADOW_LAB_ENABLED=true                   # paper/shadow: teste réellement les variantes sur prix observes
SETUP_SHADOW_CONTINUE_IN_LIVE=true              # garde le shadow paper actif meme si live est debloque plus tard
SETUP_SHADOW_DB_PATH=data/setup_shadow_lab.db   # base separee du ledger paper officiel
SETUP_SHADOW_VIRTUAL_CAPITAL_EUR=100            # capital virtuel isole par variante testee
SETUP_SHADOW_MIN_TICK_SECONDS=30                # cadence max de simulation par paire
SETUP_SHADOW_PERSIST_INTERVAL_SECONDS=60        # cadence de persistance SQLite shadow
SETUP_SHADOW_MAX_VARIANTS_PER_SYMBOL=5          # variantes simultanees par paire
SETUP_SHADOW_MIN_ORDER_EUR=5                    # ignore les ordres shadow trop petits
SETUP_SHADOW_FEE_BPS_PER_SIDE=8                 # cout frais par jambe pour shadow setup
SETUP_SHADOW_SLIPPAGE_BPS_PER_SIDE=2            # slippage prudent par jambe pour shadow setup
SETUP_SHADOW_STOP_LOSS_MULTIPLIER=3             # stop virtuel = TP grid estime * multiplicateur
SETUP_SHADOW_MIN_SAMPLES=20                     # donnees minimales avant lecture shadow
SETUP_SHADOW_MIN_CLOSED_TRADES=8                # clotures minimales avant candidat shadow
SETUP_SHADOW_CANDIDATE_SCORE=65                 # score shadow candidat
SETUP_SHADOW_CANDIDATE_PF=1.15                  # PF shadow minimum candidat
SETUP_SHADOW_WEAK_SCORE=40                      # score shadow faible
TREND_SHADOW_LAB_ENABLED=true                   # paper/shadow: teste un moteur trend/momentum sans ordre officiel
TREND_SHADOW_CONTINUE_IN_LIVE=true              # garde le shadow trend actif meme si le live est debloque plus tard
TREND_SHADOW_DB_PATH=data/trend_shadow_lab.db   # base separee du ledger paper officiel
TREND_SHADOW_VIRTUAL_CAPITAL_EUR=100            # capital virtuel isole par variante trend testee
TREND_SHADOW_MIN_TICK_SECONDS=10                # cadence max de simulation par paire
TREND_SHADOW_PERSIST_INTERVAL_SECONDS=60        # cadence de persistance SQLite shadow trend
TREND_SHADOW_MAX_VARIANTS_PER_SYMBOL=4          # variantes trend simultanees par paire
TREND_SHADOW_MAX_PRICE_SAMPLES=512              # historique prix garde par variante
TREND_SHADOW_MIN_ORDER_EUR=5                    # ignore les ordres shadow trop petits
TREND_SHADOW_FEE_BPS_PER_SIDE=12                # frais par jambe pour shadow trend
TREND_SHADOW_SLIPPAGE_BPS_PER_SIDE=3            # slippage prudent par jambe pour shadow trend
TREND_SHADOW_MIN_SAMPLES=24                     # donnees minimales avant lecture trend
TREND_SHADOW_MIN_CLOSED_TRADES=5                # clotures minimales avant candidat trend
TREND_SHADOW_CANDIDATE_SCORE=70                 # score trend candidat
TREND_SHADOW_CANDIDATE_PF=1.25                  # PF trend minimum candidat
TREND_SHADOW_WEAK_SCORE=40                      # score trend faible
MEAN_REVERSION_SHADOW_LAB_ENABLED=true          # paper/shadow: teste mean-reversion sans ordre officiel
MEAN_REVERSION_SHADOW_CONTINUE_IN_LIVE=true     # garde le shadow mean-reversion actif plus tard
MEAN_REVERSION_SHADOW_DB_PATH=data/mean_reversion_shadow_lab.db # base separee du ledger officiel
MEAN_REVERSION_SHADOW_VIRTUAL_CAPITAL_EUR=100   # capital virtuel isole par variante mean-reversion
MEAN_REVERSION_SHADOW_MIN_TICK_SECONDS=10       # cadence max de simulation par paire
MEAN_REVERSION_SHADOW_PERSIST_INTERVAL_SECONDS=60 # cadence de persistance SQLite
MEAN_REVERSION_SHADOW_MAX_VARIANTS_PER_SYMBOL=4 # variantes mean-reversion simultanees par paire
MEAN_REVERSION_SHADOW_MAX_PRICE_SAMPLES=512     # historique prix garde par variante
MEAN_REVERSION_SHADOW_MIN_ORDER_EUR=5           # ignore les ordres shadow trop petits
MEAN_REVERSION_SHADOW_FEE_BPS_PER_SIDE=12       # frais par jambe pour shadow mean-reversion
MEAN_REVERSION_SHADOW_SLIPPAGE_BPS_PER_SIDE=3   # slippage prudent par jambe
MEAN_REVERSION_SHADOW_MIN_SAMPLES=24            # donnees minimales avant lecture mean-reversion
MEAN_REVERSION_SHADOW_MIN_CLOSED_TRADES=5       # clotures minimales avant candidat mean-reversion
MEAN_REVERSION_SHADOW_CANDIDATE_SCORE=70        # score mean-reversion candidat
MEAN_REVERSION_SHADOW_CANDIDATE_PF=1.25         # PF minimum candidat
MEAN_REVERSION_SHADOW_WEAK_SCORE=40             # score mean-reversion faible
STRATEGY_ROUTER_ENABLED=true                    # paper-only: compare grid/trend/mean-reversion/no-trade
STRATEGY_ROUTER_LIVE_ENABLED=false              # live inchange; aucune execution via routeur
STRATEGY_ROUTER_MIN_SHADOW_CLOSED_TRADES=5      # evidence minimale par moteur shadow
STRATEGY_ROUTER_CANDIDATE_SCORE=70              # score routeur candidat
STRATEGY_ROUTER_WATCH_SCORE=55                  # score routeur a surveiller
STRATEGY_ROUTER_WEAK_SCORE=40                   # score routeur faible
STRATEGY_ROUTER_NO_TRADE_SCORE=50               # score neutre de l'abstention
STRATEGY_ROUTER_LEARNING_SCORE_CAP=62           # cap score si pas assez de clotures shadow
PAPER_DYNAMIC_CAPITAL_REBALANCE_ENABLED=true    # paper only: deplace le budget virtuel vers les meilleurs moteurs
PAPER_DYNAMIC_REBALANCE_INTERVAL_SECONDS=1800   # cadence de reallocation du budget paper
PAPER_DYNAMIC_REBALANCE_MIN_INSTANCE_EUR=25     # budget minimal garde par moteur paper
PAPER_DYNAMIC_REBALANCE_MIN_TRANSFER_EUR=5      # ignore les micro-transferts entre moteurs
PAPER_DYNAMIC_REBALANCE_MAX_MOVE_PCT=25         # max du capital d'un moteur deplace par cycle
PAPER_DYNAMIC_REBALANCE_MIN_WEIGHT=0.02         # poids minimal dans la repartition scoree
PAPER_DYNAMIC_REBALANCE_MAX_WEIGHT=0.30         # poids maximal pour eviter le all-in sur un moteur
PAPER_DYNAMIC_REBALANCE_RESERVE_PCT=0           # pas de reserve paper inutile; le budget reste dans les moteurs
PAPER_DYNAMIC_REBALANCE_MAX_DRAWDOWN_PCT=20     # penalise les moteurs en drawdown avant reallocation
PAPER_DYNAMIC_REBALANCE_HEALTH_WEIGHT_PCT=35    # poids de la performance realisee dans la reallocation paper
PAPER_DYNAMIC_REBALANCE_MIN_HEALTH_CLOSED_TRADES=20 # preuves minimales avant reallocation par sante realisee
PAPER_DYNAMIC_REBALANCE_EARLY_WEAK_HEALTH_MIN_CLOSED_TRADES=8 # reallocation anticipee si learning perdant
PAPER_DYNAMIC_REBALANCE_WEAK_HEALTH_MULTIPLIER=0.45 # coupe le score budget des moteurs perdants confirmes
POSITION_EXIT_TPSL_ENABLED=true                 # paper: execute TP/SL via paper executor et ledger
POSITION_EXIT_TPSL_LIVE_ENABLED=false           # live verrouille tant que non valide explicitement
PAPER_PROMOTION_MIN_CLOSED_TRADES=30            # minimum trades clotures avant recommandation live
PAPER_PROMOTION_MIN_NET_PNL_EUR=10              # minimum PnL net avant recommandation live

SQLITE_BUSY_TIMEOUT_MS=30000                    # attend les verrous SQLite courts au lieu d'echouer tout de suite
SQLITE_WRITE_RETRIES=5                          # retries sur "database is locked"
SQLITE_RETRY_BASE_DELAY_MS=50                   # base backoff en millisecondes

# ==============================
# Regime scoring Markov/Entropy
# ==============================
REGIME_SCORING_ENABLED=true                     # score-only: ajuste le classement, ne bloque jamais seul
REGIME_ENTROPY_WINDOW=64                        # fenetre entropy sur log returns
REGIME_MARKOV_WINDOW=96                         # fenetre transitions DOWN/FLAT/UP/VOLATILE
REGIME_MIN_SAMPLES=32                           # retourne unknown neutre si historique insuffisant
REGIME_HIGH_ENTROPY_THRESHOLD=0.78              # chaos potentiel si incertitude elevee
REGIME_LOW_ENTROPY_THRESHOLD=0.45               # regime calme si incertitude basse
REGIME_SCORE_WEIGHT=8                           # impact borne sur score opportunite: -8 a +8
REGIME_FLAT_RETURN_BPS=3                        # retour considere FLAT
REGIME_VOLATILE_RETURN_BPS=30                   # retour considere VOLATILE

# ==============================
# Validation quant paper/shadow
# ==============================
QUANT_VALIDATION_ENABLED=true                   # expose /api/quant/validation; observation uniquement
SHADOW_TRADING_CONTINUE_IN_LIVE=true            # conserve la couche paper/shadow meme si le live est un jour debloque
VOL_FORECAST_ENABLED=true                       # EWMA + GARCH-like leger, aucun ordre declenche
VOL_FORECAST_WINDOWS=16,32,64                   # fenetres de volatilite realisee
VOL_FORECAST_MIN_SAMPLES=20                     # retourne unknown si historique insuffisant
VOL_FORECAST_EWMA_LAMBDA=0.94                   # memoire EWMA
VOL_FORECAST_GARCH_ALPHA=0.10                   # poids choc recent
VOL_FORECAST_GARCH_BETA=0.85                    # poids memoire volatilite
VOL_FORECAST_GARCH_FLOOR_BPS=2                  # plancher numerique de volatilite
VOL_FORECAST_LOW_BPS=8                          # regime trop calme
VOL_FORECAST_HIGH_BPS=60                        # regime volatil
VOL_FORECAST_EXTREME_BPS=160                    # regime extreme, prudence
BACKTEST_QUALITY_MIN_TRADES=30                  # minimum de trades clotures avant jugement robuste
BACKTEST_QUALITY_PBO_FOLDS=4                    # proxy PBO par splits train/OOS
BACKTEST_QUALITY_TRIALS=20                      # penalite selection DSR proxy
BACKTEST_QUALITY_PBO_CAUTION=0.30               # zone prudente
BACKTEST_QUALITY_PBO_BLOCK=0.50                 # risque overfit trop eleve
BACKTEST_QUALITY_DSR_MIN_PROBABILITY=0.50       # probabilite DSR minimale avant candidat

# ==============================
# Colony Manager paper-first
# ==============================
COLONY_MANAGER_ENABLED=true                     # expose /api/colony; control-plane uniquement
COLONY_PAPER_AUTOPILOT_ENABLED=true            # autopilote borne actif en paper
COLONY_EXECUTION_MODE=logical_children          # route les instances paper existantes vers les moteurs logiques
COLONY_AUTO_SCALE_PAPER_CHILDREN=true           # augmente le nombre de moteurs logiques selon les paires surveillees
COLONY_TARGET_LIVE_CAPITAL_EUR=500              # capital live cible a simuler sans changer le solde paper reel
COLONY_LIVE_MIN_KRAKEN_CAPITAL_EUR=500          # depot reel minimum detecte cote backend avant toute promotion live
COLONY_REQUIRE_HUMAN_LIVE_UNLOCK=true           # exige un deblocage humain meme si les metriques sont bonnes
COLONY_CHILD_BEHAVIORS=core,momentum,volatility,mean_reversion
COLONY_MAX_PAPER_CHILDREN=12
COLONY_MAX_LIVE_CHILDREN=0                      # aucun moteur live sans deblocage explicite
COLONY_PARENT_RESERVE_PCT=35
COLONY_MAX_TOTAL_ACTIVE_PCT=40
COLONY_MIN_CHILD_CAPITAL_EUR=75
COLONY_MIN_LOGICAL_CHILD_CAPITAL_EUR=25         # budget minimal indicatif pour un moteur logique paper
COLONY_MAX_CHILD_SYMBOLS=6
COLONY_MIN_VALIDATION_TRADES=50
COLONY_MIN_VALIDATION_DAYS=7
COLONY_MIN_PROFIT_FACTOR=1.25
COLONY_MIN_NET_PNL_PCT=1
COLONY_MAX_CHILD_DRAWDOWN_PCT=8
COLONY_DAILY_LOSS_LIMIT_PCT=2
COLONY_MIN_SPLIT_PARENT_CAPITAL_EUR=2000
COLONY_SPLIT_CHILD_CAPITAL_PCT=25
COLONY_MAX_SPLITS_PER_BOT=1
COLONY_AUTO_LIVE_PROMOTION=false                # false tant que passage live non valide humainement
COLONY_MAX_AUTO_LIVE_CAPITAL_EUR=0
COLONY_LEVERAGE_ENABLED=false
COLONY_MAX_LEVERAGE=1

# Qualite du signal Grid
GRID_ENTRY_TOUCH_BPS=15                         # BUY seulement pres du niveau de grille, pas sur un prix deja eloigne

# Qualite execution paper (simulation plus proche Kraken)
PAPER_MAKER_FEE_BPS=25                          # frais maker paper Kraken-like (0.25%)
PAPER_TAKER_FEE_BPS=40                          # frais taker paper Kraken-like (0.40%)
PAPER_MAKER_REALISM_ENABLED=true                # post-only paper exige un carnet plausible
PAPER_MAKER_REQUIRE_BOOK=true                   # pas de fill maker invente si carnet absent
PAPER_MAKER_TOUCH_BPS=2                         # le prix limite doit toucher le meilleur bid/ask
PAPER_MAKER_MAX_SPREAD_BPS=12                   # refuse les fills maker si spread trop large
PAPER_MAKER_MAX_ADVERSE_RISK=0.58               # refuse si pression carnet contre le trade
PAPER_MAKER_MIN_DEPTH_EUR=50                    # profondeur minimale pour remplir un ordre paper
MICROSTRUCTURE_GUARD_ENABLED=true               # filtre spread/profondeur/pression carnet avant execution
MICROSTRUCTURE_MAX_ADVERSE_RISK=0.62
MICROSTRUCTURE_MIN_DEPTH_EUR=35
MICROSTRUCTURE_MAX_BOOK_AGE_MS=5000

# ==============================
# Intégrations exchange (règle conditionnelle explicite)
# ==============================
# Obligatoire si PREFLIGHT complet (connectivité exchange) ou PAPER réel connecté.
# Non requis uniquement en mode offline/mock pur avec MOCK_BROKER=true.
KRAKEN_API_KEY=                                 # requis hors offline/mock
KRAKEN_API_SECRET=                              # requis hors offline/mock

# ==============================
# Mode offline/mock pur
# ==============================
MOCK_BROKER=false                               # true => bypass exchange réel (KRAKEN_* non requis)

# ==============================
# Options runtime (defaults sûrs / conservateurs)
