# Configuration API Kraken pour AUTOBOT
# Copiez ce fichier en .env et remplissez vos clés

# Clés API Kraken (obligatoire pour trading réel)
KRAKEN_API_KEY=votre_clé_api_ici
KRAKEN_API_SECRET=votre_secret_api_ici

# Configuration Dashboard API (optionnel)
# DASHBOARD_API_TOKEN=votre_token_secret_pour_dashboard
# Si défini, le dashboard nécessite ce token pour l'accès

# Configuration optionnelle
# KRAKEN_API_URL=https://api.kraken.com

# Mode test (paper trading)
# TEST_MODE=true
