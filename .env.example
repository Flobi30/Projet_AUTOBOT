# AUTOBOT Configuration
# Copiez ce fichier en .env et remplissez vos valeurs

# ============================================
# MODE (CRITIQUE: Laissez true jusqu'à être prêt)
# ============================================
AUTOBOT_SANDBOX=true
# Pour passer en production (ORDRES RÉELS), décommentez ET mettez les deux:
# AUTOBOT_SANDBOX=false
# AUTOBOT_PRODUCTION_CONFIRMED=YES_I_KNOW_WHAT_IM_DOING

# ============================================
# API KRAKEN (requis en production)
# ============================================
# KRAKEN_API_KEY=votre_cle_api_ici
# KRAKEN_API_SECRET=votre_secret_api_ici

# ============================================
# TRADING SETTINGS
# ============================================
AUTOBOT_SYMBOL=XXBTZEUR
AUTOBOT_CAPITAL=500.0
AUTOBOT_NUM_LEVELS=14
AUTOBOT_RANGE_PERCENT=14.0

# ============================================
# SÉCURITÉ
# ============================================
AUTOBOT_MAX_ORDER_VALUE=100.0
AUTOBOT_MAX_VOLUME=0.01
AUTOBOT_MAX_POSITIONS=10
AUTOBOT_MAX_DRAWDOWN=20.0

# ============================================
# PERFORMANCE
# ============================================
AUTOBOT_POLL_INTERVAL=30
